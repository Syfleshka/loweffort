# Используется docker-compose.yml для поднятия PostgreSQL.
# Скопируй этот файл в .env и подставь реальные значения:
#   cp .env.example .env
#
# ВАЖНО: пароль должен совпадать с тем, что в backend/.env (DATABASE_URL),
# иначе бэкенд не подключится к контейнеру.
POSTGRES_USER=loweffort
POSTGRES_PASSWORD=change_me
POSTGRES_DB=loweffort
