# ─── PostgreSQL ────────────────────────────────────────────────
# Формат: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL="postgresql://gamesite:change_me@localhost:5432/gamesite_db"

# ─── better-auth ───────────────────────────────────────────────
# Сгенерировать секрет (32+ байта):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET="replace_with_long_random_string"

# Базовый URL бэкенда (на котором слушает Fastify).
# В dev — http://localhost:3000, в prod — https://your-domain.com
BETTER_AUTH_URL="http://localhost:3000"

# ─── Frontend ──────────────────────────────────────────────────
# Используется для CORS и Socket.io origin.
# В dev — http://localhost:5173, в prod — https://your-domain.com
FRONTEND_URL="http://localhost:5173"

# ─── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
